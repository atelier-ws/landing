---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav";
import Footer from "../components/Footer";
import BlogContentEnhancer from "../components/BlogContentEnhancer.astro";
import ArticleSummary from "../components/ArticleSummary.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const readingMinutes = (body: string | undefined) =>
  Math.max(1, Math.ceil((body ?? "").trim().split(/\s+/).filter(Boolean).length / 220));

// Render each post's full content for inline display.
const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  }),
);

const blogStructuredData = {
  "@type": "Blog",
  "@id": "https://atelier.ws/blog#blog",
  name: "Atelier Blog",
  url: "https://atelier.ws/blog",
  description:
    "Engineering notes about Atelier, coding-agent runtimes, code intelligence, and context economics.",
  inLanguage: "en",
  publisher: { "@id": "https://atelier.ws/#organization" },
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    "@id": `https://atelier.ws/blog/${post.id}#article`,
    headline: post.data.title,
    url: `https://atelier.ws/blog/${post.id}`,
    datePublished: post.data.date.toISOString(),
    dateModified: post.data.updated.toISOString(),
    image: new URL(post.data.image, "https://atelier.ws").toString(),
  })),
};
---

<Layout
  title="Atelier Blog: Coding-Agent Runtime Engineering"
  description="Engineering notes on how Atelier works, coding-agent cost, code intelligence, context engineering, verification, and MCP runtime design."
  canonicalPath="/blog"
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
  ]}
  structuredData={[blogStructuredData]}
  keywords={[
    "Atelier blog",
    "coding agent runtime",
    "MCP server",
    "code intelligence",
    "context engineering",
    "coding agent cost",
  ]}
>
  <Nav client:load />
  <main id="main-content">
    <div class="blog-list">
      <header class="blog-list-header">
        <p class="blog-eyebrow">Engineering notes</p>
        <h1>How coding-agent runtimes work</h1>
      </header>

      <div class="blog-articles">
        {
          renderedPosts.map((r) => {
            const { Content } = r;
            const { post } = r;
            return (
              <article class="blog-entry" data-reveal id={post.id}>
                <div class="blog-entry-header">
                  <div class="blog-entry-meta">
                    <span>By {post.data.author}</span>
                    <span aria-hidden="true">/</span>
                    <time datetime={post.data.date.toISOString()}>
                      Published {dateFmt(post.data.date)}
                    </time>
                    <span aria-hidden="true">/</span>
                    <span>{readingMinutes(post.body)} min read</span>
                    <span aria-hidden="true">/</span>
                    <span>{post.data.difficulty}</span>
                    {post.data.updated.valueOf() !==
                      post.data.date.valueOf() && (
                      <>
                        <span aria-hidden="true">/</span>
                        <time datetime={post.data.updated.toISOString()}>
                          Updated {dateFmt(post.data.updated)}
                        </time>
                      </>
                    )}
                  </div>
                  <h2>
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <p class="blog-entry-desc">{post.data.description}</p>
                  <ArticleSummary
                    id={`article-summary-${post.id}`}
                    summary={post.data.summary}
                  />
                  <ul class="post-tags" aria-label="Topics">
                    {post.data.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                </div>
                <div class="post-content">
                  <Content />
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </main>
  <Footer />
  <BlogContentEnhancer />
  {
    renderedPosts.length > 0 && (
      <nav
        class="blog-timeline"
        data-blog-timeline
        aria-label="Jump to a blog post by publication date"
      >
        <button
          type="button"
          class="blog-timeline-label"
          aria-label={`Scroll to ${renderedPosts[0].post.data.title}`}
        >
          <time>{dateFmt(renderedPosts[0].post.data.date)}</time>
          <span>{renderedPosts[0].post.data.title}</span>
        </button>
        <div class="blog-timeline-track">
          <span class="blog-timeline-thumb" aria-hidden="true"></span>
          {renderedPosts.map(({ post }, index) => {
            const position =
              renderedPosts.length > 1
                ? (index / (renderedPosts.length - 1)) * 100
                : 50;
            const date = dateFmt(post.data.date);
            return (
              <button
                type="button"
                class="blog-timeline-dot"
                style={`top: ${position}%`}
                data-target={post.id}
                data-date={date}
                data-title={post.data.title}
                aria-label={`Scroll to ${date}: ${post.data.title}`}
              />
            );
          })}
        </div>
      </nav>
    )
  }
  <script is:inline>
    (function () {
      var timeline = document.querySelector("[data-blog-timeline]");
      if (!timeline) return;

      var track = timeline.querySelector(".blog-timeline-track");
      var label = timeline.querySelector(".blog-timeline-label");
      var labelDate = label && label.querySelector("time");
      var labelTitle = label && label.querySelector("span");
      var dots = Array.prototype.slice.call(
        timeline.querySelectorAll(".blog-timeline-dot"),
      );
      if (!track || !labelDate || !labelTitle || dots.length === 0) return;

      var activeIndex = 0;
      var previewIndex = -1;
      var dragging = false;
      var ticking = false;
      var reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      function targetFor(dot) {
        return document.getElementById(dot.getAttribute("data-target") || "");
      }

      function maximumScroll() {
        return Math.max(
          0,
          document.documentElement.scrollHeight - window.innerHeight,
        );
      }

      function targetTop(dot) {
        var target = targetFor(dot);
        if (!target) return 0;
        return Math.max(
          0,
          Math.min(
            maximumScroll(),
            target.getBoundingClientRect().top + window.scrollY - 96,
          ),
        );
      }

      function positionDots() {
        var limit = maximumScroll();
        dots.forEach(function (dot) {
          var position = limit > 0 ? (targetTop(dot) / limit) * 100 : 50;
          dot.style.top = position + "%";
        });
        showLabel(previewIndex >= 0 ? previewIndex : activeIndex);
      }

      function showLabel(index) {
        var dot = dots[index];
        if (!dot) return;
        labelDate.textContent = dot.getAttribute("data-date") || "";
        labelTitle.textContent = dot.getAttribute("data-title") || "";
        label.setAttribute(
          "aria-label",
          "Scroll to " + (dot.getAttribute("data-title") || "blog post"),
        );
        timeline.style.setProperty("--label-position", dot.style.top);
      }

      function setActive(index) {
        activeIndex = index;
        dots.forEach(function (dot, dotIndex) {
          var isActive = dotIndex === index;
          dot.classList.toggle("is-active", isActive);
          if (isActive) {
            dot.setAttribute("aria-current", "date");
          } else {
            dot.removeAttribute("aria-current");
          }
        });
        if (previewIndex < 0 && !dragging) showLabel(index);
      }

      function update() {
        var nextIndex = 0;
        for (var i = dots.length - 1; i >= 0; i--) {
          var target = targetFor(dots[i]);
          if (target && target.getBoundingClientRect().top <= 160) {
            nextIndex = i;
            break;
          }
        }
        setActive(nextIndex);
        var limit = maximumScroll();
        var position = limit > 0 ? (window.scrollY / limit) * 100 : 0;
        timeline.style.setProperty("--scroll-position", position + "%");
      }

      function scrollToDot(index) {
        window.scrollTo({
          top: targetTop(dots[index]),
          behavior: reducedMotion ? "auto" : "smooth",
        });
      }

      function closestDot(ratio) {
        var closestIndex = 0;
        var closestDistance = Infinity;
        dots.forEach(function (dot, index) {
          var position = (parseFloat(dot.style.top) || 0) / 100;
          var distance = Math.abs(position - ratio);
          if (distance < closestDistance) {
            closestIndex = index;
            closestDistance = distance;
          }
        });
        return closestIndex;
      }

      function scrub(clientY) {
        var bounds = track.getBoundingClientRect();
        var ratio = Math.max(
          0,
          Math.min(1, (clientY - bounds.top) / bounds.height),
        );
        dragging = true;
        previewIndex = closestDot(ratio);
        timeline.classList.add("is-interacting");
        showLabel(previewIndex);
        window.scrollTo({ top: ratio * maximumScroll(), behavior: "auto" });
      }

      dots.forEach(function (dot, index) {
        dot.addEventListener("mouseenter", function () {
          previewIndex = index;
          timeline.classList.add("is-interacting");
          showLabel(index);
        });
        dot.addEventListener("mouseleave", function () {
          if (dragging) return;
          previewIndex = -1;
          timeline.classList.remove("is-interacting");
          showLabel(activeIndex);
        });
        dot.addEventListener("focus", function () {
          previewIndex = index;
          timeline.classList.add("is-interacting");
          showLabel(index);
        });
        dot.addEventListener("blur", function () {
          previewIndex = -1;
          timeline.classList.remove("is-interacting");
          showLabel(activeIndex);
        });
        dot.addEventListener("click", function () {
          scrollToDot(index);
        });
      });

      label.addEventListener("click", function () {
        scrollToDot(previewIndex >= 0 ? previewIndex : activeIndex);
      });

      track.addEventListener("pointerdown", function (event) {
        if (event.target.closest(".blog-timeline-dot")) return;
        event.preventDefault();
        track.setPointerCapture(event.pointerId);
        scrub(event.clientY);
      });
      track.addEventListener("pointermove", function (event) {
        if (track.hasPointerCapture(event.pointerId)) scrub(event.clientY);
      });
      track.addEventListener("pointerup", function (event) {
        if (track.hasPointerCapture(event.pointerId)) {
          track.releasePointerCapture(event.pointerId);
        }
        dragging = false;
        previewIndex = -1;
        timeline.classList.remove("is-interacting");
        update();
      });
      track.addEventListener("pointercancel", function () {
        dragging = false;
        previewIndex = -1;
        timeline.classList.remove("is-interacting");
        update();
      });

      window.addEventListener(
        "scroll",
        function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function () {
            update();
            ticking = false;
          });
        },
        { passive: true },
      );

      window.addEventListener("resize", positionDots, { passive: true });
      window.addEventListener("load", positionDots, { once: true });
      if (typeof ResizeObserver !== "undefined") {
        new ResizeObserver(positionDots).observe(document.body);
      }

      positionDots();
      update();
    })();
  </script>
</Layout>
