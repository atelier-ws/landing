---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav";
import Hero from "../components/Hero";
import InstallCmd from "../components/InstallCmd";
import ProblemSolution from "../components/ProblemSolution";
import SavingsStack from "../components/SavingsStack";

import HostsList from "../components/HostsList";
import StatsSection from "../components/StatsSection";
import Providers from "../components/Providers";
import HowItWorks from "../components/HowItWorks";
import CtaSection from "../components/CtaSection";
import Footer from "../components/Footer";
---
<Layout>
  <!-- Navigation -->
  <Nav client:load />

  <!-- Hero -->
  <div data-reveal><Hero client:load /></div>

  <!-- Problem / Solution -->
  <div data-reveal><ProblemSolution client:load /></div>

  <!-- Install -->
  <div data-reveal><InstallCmd client:load /></div>

  <!-- Savings Stack -->
  <div data-reveal><SavingsStack client:load /></div>

  <!-- Stats -->
  <div data-reveal><StatsSection client:load /></div>

  <!-- Hosts -->
  <div data-reveal><HostsList client:load /></div>

  <!-- Providers -->
  <div data-reveal><Providers client:load /></div>

  <!-- How It Works -->
  <div data-reveal><HowItWorks client:load /></div>

  <!-- CTA -->
  <div data-reveal><CtaSection client:load /></div>

  <!-- Footer -->
  <Footer client:load />
</Layout>
