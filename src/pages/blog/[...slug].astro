---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";
import BlogTimeline from "../../components/BlogTimeline.astro";
import BlogContentEnhancer from "../../components/BlogContentEnhancer.astro";
import ArticleSummary from "../../components/ArticleSummary.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = (await getCollection("blog"))
  .filter((candidate) => candidate.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const canonicalUrl = `https://atelier.ws/blog/${post.id}`;
const imageUrl = new URL(post.data.image, "https://atelier.ws").toString();
const publishedTime = post.data.date.toISOString();
const modifiedTime = post.data.updated.toISOString();
const wasUpdated = post.data.updated.valueOf() !== post.data.date.valueOf();
const wordCount = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));
const sectionHeadings = headings;
const timelineItems = [
  {
    target: post.id,
    meta: "H1",
    title: post.data.title,
    level: 1,
  },
  ...sectionHeadings.map((heading) => ({
    target: heading.slug,
    meta: `H${heading.depth}`,
    title: heading.text,
    level: heading.depth,
  })),
];

const articleStructuredData = {
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  url: canonicalUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  image: {
    "@type": "ImageObject",
    url: imageUrl,
    width: 1200,
    height: 630,
  },
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: {
    "@type": "Organization",
    "@id": "https://atelier.ws/#organization",
    name: post.data.author,
    url: "https://atelier.ws/",
  },
  publisher: { "@id": "https://atelier.ws/#organization" },
  isPartOf: { "@id": "https://atelier.ws/blog#blog" },
  inLanguage: "en",
  articleSection: "Engineering",
  keywords: post.data.tags.join(", "),
  wordCount,
  timeRequired: `PT${readingTime}M`,
};
---

<Layout
  title={`${post.data.title} | Atelier`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}`}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  articleSection="Engineering"
  articleTags={post.data.tags}
  keywords={[...post.data.tags, "Atelier", "coding agents"]}
  structuredData={[articleStructuredData]}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: `/blog/${post.id}` },
  ]}
>
  <Nav client:load />
  <main id="main-content">
    <article class="post-page" id={post.id}>
      <div class="post-header">
        <a href="/blog" class="post-back">&larr; Back to all posts</a>
        <div class="post-byline">
          <span>By {post.data.author}</span>
          <span aria-hidden="true">/</span>
          <time datetime={publishedTime}>Published {dateFmt(post.data.date)}</time>
          <span aria-hidden="true">/</span>
          <span>{readingTime} min read</span>
          <span aria-hidden="true">/</span>
          <span>{post.data.difficulty}</span>
          {
            wasUpdated && (
              <>
                <span aria-hidden="true">/</span>
                <time datetime={modifiedTime}>
                  Updated {dateFmt(post.data.updated)}
                </time>
              </>
            )
          }
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        <ArticleSummary id="post-learning-heading" summary={post.data.summary} />
        <ul class="post-tags" aria-label="Topics">
          {post.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </div>
      <div class="post-content">
        <Content />
      </div>
    </article>

    {
      allPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-heading">
          <hr class="related-divider" />
          <h2 id="related-heading" class="related-heading">More from the blog</h2>
          <div class="related-grid">
            {allPosts.map((relatedPost) => (
              <a href={`/blog/${relatedPost.id}`} class="related-card">
                <time
                  class="related-card-date"
                  datetime={relatedPost.data.date.toISOString()}
                >
                  {dateFmt(relatedPost.data.date)}
                </time>
                <h3 class="related-card-title">{relatedPost.data.title}</h3>
                <p class="related-card-meta">
                  {relatedPost.data.category} · {relatedPost.data.difficulty}
                </p>
                <p class="related-card-excerpt">{relatedPost.data.excerpt}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
  <BlogContentEnhancer />
  <BlogTimeline
    items={timelineItems}
    ariaLabel="Jump to a section of this article"
  />
</Layout>
