---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = (await getCollection("blog"))
  .filter((candidate) => candidate.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const canonicalUrl = `https://atelier.ws/blog/${post.id}`;
const imageUrl = new URL(post.data.image, "https://atelier.ws").toString();
const publishedTime = post.data.date.toISOString();
const modifiedTime = post.data.updated.toISOString();
const wasUpdated = post.data.updated.valueOf() !== post.data.date.valueOf();
const wordCount = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const sectionHeadings = headings.filter(h => h.depth <= 3);
const sectionSlugs = sectionHeadings.map(h => h.slug);
const headingsBySlug = Object.fromEntries(
  sectionHeadings.map(h => [h.slug, h.text]),
);

const articleStructuredData = {
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  url: canonicalUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  image: {
    "@type": "ImageObject",
    url: imageUrl,
    width: 1200,
    height: 630,
  },
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: {
    "@type": "Organization",
    "@id": "https://atelier.ws/#organization",
    name: post.data.author,
    url: "https://atelier.ws/",
  },
  publisher: { "@id": "https://atelier.ws/#organization" },
  isPartOf: { "@id": "https://atelier.ws/blog#blog" },
  inLanguage: "en",
  articleSection: "Engineering",
  keywords: post.data.tags.join(", "),
  wordCount,
};
---

<Layout
  title={`${post.data.title} | Atelier`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}`}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  articleSection="Engineering"
  articleTags={post.data.tags}
  keywords={[...post.data.tags, "Atelier", "coding agents"]}
  structuredData={[articleStructuredData]}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: `/blog/${post.id}` },
  ]}
>
  <Nav client:load />
  <main id="main-content">
    <article class="post-page">
      <div class="post-header">
        <a href="/blog" class="post-back">&larr; Back to all posts</a>
        <div class="post-byline">
          <span>By {post.data.author}</span>
          <span aria-hidden="true">/</span>
          <time datetime={publishedTime}>Published {dateFmt(post.data.date)}</time>
          {
            wasUpdated && (
              <>
                <span aria-hidden="true">/</span>
                <time datetime={modifiedTime}>
                  Updated {dateFmt(post.data.updated)}
                </time>
              </>
            )
          }
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        <ul class="post-tags" aria-label="Topics">
          {post.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </div>
      <div class="post-content">
        <Content />
      </div>
    </article>

    {
      allPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-heading">
          <hr class="related-divider" />
          <h2 id="related-heading" class="related-heading">More from the blog</h2>
          <div class="related-grid">
            {allPosts.map((relatedPost) => (
              <a href={`/blog/${relatedPost.id}`} class="related-card">
                <time
                  class="related-card-date"
                  datetime={relatedPost.data.date.toISOString()}
                >
                  {dateFmt(relatedPost.data.date)}
                </time>
                <h3 class="related-card-title">{relatedPost.data.title}</h3>
                <p class="related-card-excerpt">{relatedPost.data.excerpt}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
  <div class="si" aria-hidden="true" data-slugs={JSON.stringify(sectionSlugs)} data-headings={JSON.stringify(headingsBySlug)}>
    <div class="si-label" id="si-label">{dateFmt(post.data.date)}</div>
    <div class="si-track"></div>
  </div>
  <script is:inline>
    (function() {
      var el = document.querySelector(".si");
      if (!el) return;
      var slugs, textLookup;
      try {
        slugs = JSON.parse(el.getAttribute("data-slugs") || "[]");
        textLookup = JSON.parse(el.getAttribute("data-headings") || "{}");
      } catch(e) { return; }
      if (slugs.length === 0) return;

      var label = document.getElementById("si-label");
      if (!label) return;

      var track = el.querySelector(".si-track");
      var hoverIdx = -1;

      slugs.forEach(function(slug, i) {
        var mark = document.createElement("span");
        mark.className = "si-mark";
        mark.setAttribute("data-idx", i);
        // position proportionally along the track
        var pct = slugs.length > 1 ? (i / (slugs.length - 1)) * 100 : 50;
        mark.style.top = pct + "%";

        // hover – show heading text in label
        mark.addEventListener("mouseenter", function() {
          hoverIdx = i;
          label.textContent = textLookup[slugs[i]] || "";
        });
        mark.addEventListener("mouseleave", function() {
          hoverIdx = -1;
          update();
        });
        // click – smooth-scroll to heading
        mark.addEventListener("click", function() {
          var h = document.getElementById(slugs[i]);
          if (h) h.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        track.appendChild(mark);
      });
      var marks = track.querySelectorAll(".si-mark");

      function update() {
        var active = -1;
        for (var i = slugs.length - 1; i >= 0; i--) {
          var h = document.getElementById(slugs[i]);
          if (h && h.getBoundingClientRect().top <= 120) {
            active = i;
            break;
          }
        }
        if (active < 0 && slugs.length > 0) active = 0;

        marks.forEach(function(m, idx) {
          m.classList.toggle("active", idx === active);
        });

        // only update label when not hovering a dot
        if (hoverIdx < 0 && active >= 0) {
          label.textContent = textLookup[slugs[active]] || "";
        }
      }

      var ticking = false;
      window.addEventListener("scroll", function() {
        if (!ticking) {
          requestAnimationFrame(function() { update(); ticking = false; });
          ticking = true;
        }
      });
      update();
    })();
  </script>
</Layout>
