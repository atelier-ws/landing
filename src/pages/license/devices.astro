---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";
import DeviceManager from "../../components/DeviceManager";
---

<Layout
  title="Manage your Atelier devices"
  description="View and remove the devices on your Atelier Pro license."
  canonicalPath="/license/devices"
  robots="noindex,nofollow,noarchive"
>
  <meta slot="head" name="referrer" content="no-referrer" />
  <Nav client:load />
  <main id="main-content" class="px-6 pb-24 pt-32">
    <div class="mx-auto max-w-2xl">
      <DeviceManager client:load />
    </div>
  </main>
  <Footer />
</Layout>
