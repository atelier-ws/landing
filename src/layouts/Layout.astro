---
import "../styles/global.css";

interface Breadcrumb {
  name: string;
  path: string;
}

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  breadcrumbs?: Breadcrumb[];
  robots?: string;
}

const SITE_URL = "https://atelier.ws";
const SITE_NAME = "Atelier";
const DEFAULT_TITLE =
  "Atelier - Source-Available MCP Runtime for Claude Code & Coding Agents";
const DEFAULT_DESCRIPTION =
  "Atelier is the source-available MCP runtime for Claude Code and coding agents: code intelligence, context reuse, model routing, cost tracking, and auditable traces.";
// Canonical product description for the SoftwareApplication node. Kept separate
// from the per-page meta `description` so the schema never inherits page copy.
const SOFTWARE_DESCRIPTION =
  "Atelier is a source-available runtime for coding agents: an MCP server and SDK middleware for code intelligence, context reuse, model routing, cost tracking, and auditable run traces. Runs locally alongside Claude Code, Codex, Cursor, and any MCP host.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonicalPath = "/",
  image = "/og.png",
  breadcrumbs,
  robots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1",
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, SITE_URL).toString();
const imageUrl = new URL(image, SITE_URL).toString();
const buildDate = new Date().toISOString().slice(0, 10);

const graph: Record<string, unknown>[] = [
  {
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    logo: {
      "@type": "ImageObject",
      url: `${SITE_URL}/logo.png`,
      width: 512,
      height: 512,
    },
    email: "contact@atelier.ws",
    sameAs: ["https://github.com/atelier-ws/atelier"],
  },
  {
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    inLanguage: "en",
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
  {
    "@type": "SoftwareApplication",
    "@id": `${SITE_URL}/#software`,
    name: SITE_NAME,
    applicationCategory: "DeveloperApplication",
    operatingSystem: ["Linux", "macOS"],
    url: `${SITE_URL}/`,
    downloadUrl: "https://install.atelier.ws",
    codeRepository: "https://github.com/atelier-ws/atelier",
    license: "https://fsl.software/",
    isAccessibleForFree: true,
    dateModified: buildDate,
    description: SOFTWARE_DESCRIPTION,
    offers: [
      {
        "@type": "Offer",
        name: "Free",
        price: "0",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        url: `${SITE_URL}/pricing`,
      },
      {
        "@type": "Offer",
        name: "Pro",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        url: `${SITE_URL}/pricing`,
        priceSpecification: {
          "@type": "UnitPriceSpecification",
          price: "19.00",
          priceCurrency: "USD",
          unitCode: "MON",
          billingDuration: 1,
          billingIncrement: 1,
        },
      },
      {
        "@type": "Offer",
        name: "Enterprise",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        url: `${SITE_URL}/pricing`,
        priceSpecification: {
          "@type": "PriceSpecification",
          priceCurrency: "USD",
          description: "Custom pricing - contact sales",
        },
      },
    ],
    featureList: [
      "MCP server for coding-agent hosts",
      "SDK middleware for AI agent runtimes",
      "SCIP-indexed code intelligence",
      "Context reuse and compaction",
      "Model routing and cost tracking",
      "Auditable run traces",
    ],
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
];

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((crumb, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.path, SITE_URL).toString(),
    })),
  });
}

const structuredData = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Atelier" />
    <meta name="application-name" content="Atelier" />
    <meta name="theme-color" content="#f7f8fb" />
    <meta name="keywords" content="Atelier, coding agents, MCP server, AI agent runtime, code intelligence, model routing, cost tracking, context engineering" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href="/index.md" title="Atelier landing page in Markdown" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="Atelier LLM-readable summary" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="me" href="https://github.com/atelier-ws/atelier" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Atelier" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Atelier - source-available context runtime for coding agents" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Atelier - source-available context runtime for coding agents" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <slot name="head" />
  </head>
  <body class="bg-[#f7f8fb] text-neutral-950 font-mono antialiased">
    <slot />
    <script>
      // Scroll-reveal: observe [data-reveal] elements and add .revealed class
      if (typeof IntersectionObserver !== "undefined") {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );
        // Script is at the end of <body>, so [data-reveal] elements already
        // exist — observe immediately rather than waiting for DOMContentLoaded.
        document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
