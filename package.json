{
  "name": "atelier-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro build && concurrently --kill-others-on-fail -n astro,wrangler -c cyan,magenta \"nodemon --watch src -e astro,tsx,ts,js,mjs,css,md --exec 'astro build'\" \"wrangler dev --port 4321 --log-level info\"",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "typecheck": "tsc --noEmit",
    "cf-types": "wrangler types --include-runtime false"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.1",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.7.4",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "tailwindcss": "^3.4.6",
    "wrangler": "^4.103.0"
  }
}
